+template <>
+struct std::formatter<std::vector<std::string>> : formatter<std::string>
+{
+    auto format(const std::vector<std::string> v, format_context& ctx) const
+    {
+        auto&& out= ctx.out();
+        if (v.size() > 0)
+            format_to(out, "{}", v[0]);
+        for (size_t i = 1; i < v.size(); ++i)
+            format_to(out, ";{}", v[i]);
+        return format_to(out, "");
+    }
+};
